<?xml version="1.0" encoding="utf-8"?>
<brls:Box
    width="100%"
    height="100%"
    axis="column"
    justifyContent="center"
    alignItems="center"
    grow="1"
    paddingTop="50"
    paddingBottom="50"
    paddingLeft="100"
    paddingRight="100">

    <!-- Title -->
    <brls:Label
        id="login/title"
        text="VitaSuwayomi"
        fontSize="36"
        marginBottom="40"/>

    <!-- Input container -->
    <brls:Box
        id="login/input_container"
        width="700"
        axis="column"
        alignItems="stretch"
        marginBottom="30">

        <!-- Server URL -->
        <brls:Label
            id="login/server_label"
            text="Server: Not set"
            fontSize="18"
            marginBottom="15"
            focusable="true"/>

        <!-- Username -->
        <brls:Label
            id="login/username_label"
            text="Username: (optional)"
            fontSize="18"
            marginBottom="15"
            focusable="true"/>

        <!-- Password -->
        <brls:Label
            id="login/password_label"
            text="Password: (optional)"
            fontSize="18"
            focusable="true"/>

    </brls:Box>

    <!-- Buttons -->
    <brls:Box
        axis="row"
        justifyContent="center"
        alignItems="center"
        marginBottom="20">

        <brls:Button
            id="login/login_button"
            text="Connect"
            width="180"
            height="44"
            marginRight="15"/>

        <brls:Button
            id="login/offline_button"
            text="Offline"
            width="150"
            height="44"/>

    </brls:Box>

    <!-- Status message -->
    <brls:Label
        id="login/status"
        text=""
        fontSize="16"
        horizontalAlign="center"/>

</brls:Box>
